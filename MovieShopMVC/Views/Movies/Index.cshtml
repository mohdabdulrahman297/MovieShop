@model IEnumerable<MovieShop.ApplicationCore.Models.MovieCardModel>

@{
    ViewData["Title"] = "Highest Grossing Movies";
}

<h1>Highest Grossing Movies</h1>

<div class="row">
    @foreach (var movie in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100">
                <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id">
                    <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title" />
                </a>
                <div class="card-body">
                    <h5 class="card-title">
                        <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id">
                            @movie.Title
                        </a>
                    </h5>
                </div>
            </div>
        </div>
    }
</div>