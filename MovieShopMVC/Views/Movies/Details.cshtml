@model MovieShop.ApplicationCore.Models.MovieDetailsModel

@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-3">
            <img src="@Model.PosterUrl" alt="@Model.Title" class="img-fluid rounded shadow" />
        </div>

        <div class="col-md-6">
            <h1>@Model.Title</h1>

            <div class="mb-3">
                @if (Model.Genres != null && Model.Genres.Any())
                {
                    @foreach (var genre in Model.Genres)
                    {
                        <span class="badge bg-secondary me-1">@genre.Name</span>
                    }
                }
                <span class="badge bg-warning text-dark">@Model.Rating</span>
            </div>

            <p class="text-muted">@Model.Tagline</p>
            <p>@Model.Overview</p>
        </div>

        <div class="col-md-3">
            <div class="d-grid gap-2">

                @* Buy Movie Button — opens modal *@
                @if (User.Identity!.IsAuthenticated)
                {
                    <button type="button" class="btn btn-danger"
                            data-bs-toggle="modal" data-bs-target="#buyMovieModal">
                        🛒 Buy Movie
                    </button>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-danger">
                        Login to Buy
                    </a>
                }

                @* Favorites Buttons *@
                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-controller="User" asp-action="AddFavorite" method="post">
                        <input type="hidden" name="movieId" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning w-100">
                            ⭐ Add to Favorites
                        </button>
                    </form>

                    <form asp-controller="User" asp-action="RemoveFavorite" method="post">
                        <input type="hidden" name="movieId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-warning w-100">
                            ❌ Remove Favorite
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                           class="btn btn-outline-warning">
                        Login to Favorite
                    </a>
                }

                <button type="button" class="btn btn-outline-primary"
                        data-bs-toggle="modal" data-bs-target="#reviewModal">
                    ✏️ Review
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <h4>Movie Facts</h4>
            <ul class="list-group mb-4">
                <li class="list-group-item">
                    <strong>Release Date:</strong> @Model.ReleaseDate?.ToShortDateString()
                </li>
                <li class="list-group-item">
                    <strong>Runtime:</strong> @Model.RunTime minutes
                </li>
                <li class="list-group-item">
                    <strong>Budget:</strong> @Model.Budget
                </li>
                <li class="list-group-item">
                    <strong>Revenue:</strong> @Model.Revenue
                </li>
            </ul>
        </div>

        <div class="col-md-8">
            <h4>Casts</h4>
            <ul class="list-group">
                @if (Model.Casts != null && Model.Casts.Any())
                {
                    @foreach (var cast in Model.Casts)
                    {
                        <li class="list-group-item">
                            <a asp-controller="Cast" asp-action="Details" asp-route-id="@cast.Id">
                                @cast.Name
                            </a>
                            @if (!string.IsNullOrWhiteSpace(cast.Character))
                            {
                                <span> as @cast.Character</span>
                            }
                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item">No cast information available</li>
                }
            </ul>
        </div>
    </div>
</div>

@* ✅ Buy Movie Modal — wired to UserController.BuyMovie *@
<div class="modal fade" id="buyMovieModal" tabindex="-1" aria-labelledby="buyMovieModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="buyMovieModalLabel">Confirm Purchase</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to buy <strong>@Model.Title</strong>?
                <p class="mt-2"><strong>Price:</strong> $@Model.Price</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                @* ✅ FIXED: form submits to UserController.BuyMovie *@
                <form asp-controller="User" asp-action="BuyMovie" method="post">
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Confirm Purchase</button>
                </form>
            </div>
        </div>
    </div>
</div>

@* Review Modal — unchanged *@
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reviewModalLabel">Write a Review</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <select class="form-select">
                            @for (int i = 1; i <= 10; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Review</label>
                        <textarea class="form-control" rows="4" placeholder="Write your review here"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </form>
            </div>
        </div>
    </div>
</div>