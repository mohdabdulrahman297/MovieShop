@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4">Welcome to MovieShop</h1>
    <p class="mt-3">Browse movies or open one movie details page.</p>

    <div class="mt-4">
        <a asp-controller="Movies"
               asp-action="Index"
               class="btn btn-primary me-2">
            Highest Grossing Movies
        </a>

        <a asp-controller="Movies"
               asp-action="Details"
               asp-route-id="1"
               class="btn btn-success">
            View Movie Details by Id
        </a>
    </div>
</div>